# --- Secrets: NEVER share these ---
.env

# --- The app's private box of helpers ---
.venv/
venv/

# --- Auto-generated cache database & generated images ---
data/*.db
data/*.sqlite
app/assets/generated/

# --- Disposable scratch scripts ---
.tmp/

