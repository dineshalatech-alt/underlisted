# ------------------------------------------------------------------
# NorCal Deal Finder — API keys template
# ------------------------------------------------------------------
# HOW TO USE:
#   1. Make a copy of this file named ".env"  (in PowerShell:
#         Copy-Item .env.example .env )
#   2. Paste each key after the "=" sign. No spaces. No quotes.
#   3. Save. The real ".env" file is private and never shared.
# ------------------------------------------------------------------

# RentCast — listings, value estimates, rent estimates, market stats.  (REQUIRED)
# Get it at: https://developers.rentcast.io
RENTCAST_API_KEY=

# Google Street View Static API — the real exterior house photos.      (REQUIRED)
# Enable at: https://console.cloud.google.com  (search "Street View Static API")
STREETVIEW_API_KEY=

# Foreclosure Data Hub — bank-owned / foreclosure (REO) listings.      (OPTIONAL)
# $1 trial -> $49/mo (pick the MONTHLY plan — it has API access). Key starts fdh_ak_
# Get it at: https://www.foreclosuredatahub.com/signin?plan=monthly
FORECLOSURE_API_KEY=

# HUD Fair Market Rents — FREE rent benchmark by ZIP/county.            (OPTIONAL)
# Free token (register, then "Create API key"): https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_FMR_TOKEN=

# FRED (Federal Reserve) — live 30-yr mortgage rate for "true monthly cost". (OPTIONAL)
# NOT required: without it we already use Freddie Mac's free no-key weekly rate.
# A free FRED key just lets us read the same number straight from the Fed.
# Get it at: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Resend — sends the deal-alert emails ("a deal just dropped!").       (OPTIONAL)
# Free (3,000 emails/mo). Get it at: https://resend.com -> API Keys. Key starts re_
RESEND_API_KEY=
# Optional: the "from" line on alert emails. Leave blank to use Resend's shared
# test sender (works with no domain, but only emails your own Resend address).
# Once you verify a domain in Resend, set e.g. Deal Finder <alerts@yourbrand.com>
ALERT_FROM_EMAIL=

# Google Gemini ("Nano Banana") — optional AI "imagine remodeled" images
# and one-time branding art.                                           (OPTIONAL)
# Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Shared cloud database.                                               (OPTIONAL)
# Leave BLANK to use a local SQLite file (data/cache.db) — perfect for testing.
# Set it to a hosted PostgreSQL connection string to share ONE cache between the
# background worker and all your customers, e.g.:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
# (Supabase/Neon/Railway give you this string when you create a database.)
DATABASE_URL=
